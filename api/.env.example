# ─── Database ─────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Redis ────────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a Redis plugin
REDIS_URL=redis://default:password@host:6379

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Your frontend domain (already set for shitboxshuffle.com)
WEB_BASE_URL=https://shitboxshuffle.com
API_BASE_URL=https://YOUR_RAILWAY_APP.up.railway.app

# Extra frontend origins (CORS + Socket.IO). Production always allows shitboxshuffle.com / www in code.
ALLOWED_ORIGINS=https://shitboxshuffle.com,https://www.shitboxshuffle.com

# ─── Optional: Google OAuth ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# Browser Maps JavaScript API key for GeoGuesser (session page loads it from GET /api/config/maps-key).
# In Google Cloud: enable "Maps JavaScript API" (Street View uses the same loader).
# Restrict key: HTTP referrers — e.g. https://shitboxshuffle.com/*  https://www.shitboxshuffle.com/*
GOOGLE_MAPS_API_KEY=

# ─── Optional: Stripe Payments ────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_TOKEN_PACK_PRICE_ID=

# ─── Optional: Agora Video ────────────────────────────────────────────────────
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ─── Optional: Persona KYC ────────────────────────────────────────────────────
PERSONA_API_KEY=
PERSONA_WEBHOOK_SECRET=
